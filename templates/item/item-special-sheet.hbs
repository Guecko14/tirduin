<form class="{{cssClass}} special-item-sheet" autocomplete="off">

    {{!-- Panel principal de edicion: nombre y descripcion en una sola vista
    --}}
    <section class="special-sheet-panel">
        {{!-- Cabecera con imagen editable y nombre del rasgo especial --}}
        <div class="special-header-row">
            <img
                class="special-image-picker"
                src="{{item.img}}"
                data-edit="img"
                title="{{item.name}}" />

            <div class="special-field special-field-name">
                <label for="name">Nombre</label>
                <input name="name" type="text" value="{{item.name}}"
                    placeholder="Nombre de la Habilidad Especial" />
            </div>
        </div>

        {{!-- Campo largo para describir el efecto o la regla de la habilidad
        especial --}}
        <div class="special-field special-field-description">
            <label for="system.description">Descripción</label>
            <textarea name="system.description"
                placeholder="Describe qué hace esta Habilidad Especial">{{system.description}}</textarea>
        </div>
    </section>

</form>
