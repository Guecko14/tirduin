<form class="{{cssClass}} armor-item-sheet" autocomplete="off">

    {{!-- Panel principal de edición de la armadura --}}
    <section class="armor-sheet-panel">

        {{!-- Cabecera con imagen editable y nombre de la armadura --}}
        <div class="armor-header-row">
            <img
                class="armor-image-picker"
                src="{{item.img}}"
                data-edit="img"
                title="{{item.name}}" />

            <div class="armor-field armor-field-name">
                <label for="name">Nombre</label>
                <input name="name" type="text" value="{{item.name}}"
                    placeholder="Nombre de la armadura" />
            </div>
        </div>

        {{!-- Categoría de la armadura --}}
        <div class="armor-field">
            <label for="system.category">Categoría</label>
            <select name="system.category">
                <option value="sinArmadura" {{#if (eq system.category
                    'sinArmadura')}}selected{{/if}}>Sin armadura</option>
                <option value="ligera" {{#if (eq system.category
                    'ligera')}}selected{{/if}}>Ligera</option>
                <option value="media" {{#if (eq system.category
                    'media')}}selected{{/if}}>Media</option>
                <option value="pesada" {{#if (eq system.category
                    'pesada')}}selected{{/if}}>Pesada</option>
                <option value="escudo" {{#if (eq system.category
                    'escudo')}}selected{{/if}}>Escudo</option>
                <option value="extra" {{#if (eq system.category
                    'extra')}}selected{{/if}}>Extra</option>
            </select>
        </div>

        {{!-- Fila de valores de defensa: CA + Agi max, CA rota + Agi max rota,
        VD --}}
        <div class="armor-row armor-row-defense">

            {{#if (or (eq system.category 'escudo') (eq system.category
            'extra'))}}
            <div class="armor-field armor-field-compact armor-field-defense">
                <label for="system.bonus">Bonif.</label>
                <input name="system.bonus" type="number"
                    value="{{system.bonus}}"
                    min="0" />
            </div>
            {{else}}
            <div class="armor-field armor-field-compact armor-field-defense">
                <label for="system.ca">CA</label>
                <input name="system.ca" type="number" value="{{system.ca}}"
                    min="0" />
            </div>

            <div class="armor-field armor-field-compact armor-field-defense">
                <label for="system.maxAgility">Max Agi</label>
                <input name="system.maxAgility" type="number"
                    value="{{system.maxAgility}}" min="-5" max="5" />
            </div>

            <div class="armor-field armor-field-compact armor-field-defense">
                <label for="system.caBroken">CA rota</label>
                <input name="system.caBroken" type="number"
                    value="{{system.caBroken}}" min="0" />
            </div>

            <div
                class="armor-field armor-field-compact armor-field-defense armor-field-max-agi-broken">
                <label for="system.maxAgilityBroken">Max Agi R</label>
                <input name="system.maxAgilityBroken" type="number"
                    value="{{system.maxAgilityBroken}}" min="-5" max="5" />
            </div>
            {{/if}}

            {{#unless (eq system.category 'extra')}}
            <div class="armor-field armor-field-vd armor-field-defense">
                <label for="system.vd"
                    title="Valor Defensivo: tirada de dados">VD</label>
                <input name="system.vd" type="text" value="{{system.vd}}"
                    placeholder="1d6" />
            </div>
            {{/unless}}

        </div>

        {{!-- Fila de Resistencia de Armadura (RA): máxima + actual --}}
        {{#unless (eq system.category 'extra')}}
        <div class="armor-row armor-row-ra">

            <div class="armor-field">
                <label for="system.ra" title="Resistencia de Armadura máxima">RA
                    máx.</label>
                <input name="system.ra" type="number" value="{{system.ra}}"
                    min="0" />
            </div>

            <div class="armor-field">
                <label for="system.raCurrent"
                    title="Resistencia de Armadura actual">RA actual</label>
                <input name="system.raCurrent" type="number"
                    value="{{system.raCurrent}}" min="0" max="{{system.ra}}" />
            </div>

        </div>
        {{/unless}}

        {{!-- Resistencia (R): valor numérico + tipo de daño (no aplica a
        escudos ni extras) --}}
        {{#unless (or (eq system.category 'escudo') (eq system.category
        'extra'))}}
        <div class="armor-row armor-row-resistance">

            <div class="armor-field">
                <label for="system.resistance.value"
                    title="Valor de resistencia">R (valor)</label>
                <input name="system.resistance.value" type="number"
                    value="{{system.resistance.value}}" min="0" />
            </div>

            <div class="armor-field">
                <label for="system.resistance.damageType"
                    title="Tipo de daño al que aplica la Resistencia">R (tipo
                    daño)</label>
                <select name="system.resistance.damageType">
                    <option value>— Ninguno —</option>
                    {{#each config.damageTypes as |label key|}}
                    <option value="{{key}}"
                        {{#if (eq ../system.resistance.damageType
                        key)}}selected{{/if}}>
                        {{localize label}}
                    </option>
                    {{/each}}
                </select>
            </div>

        </div>
        {{/unless}}

        {{!-- Fila de datos de equipamiento: Vigor, rota, sigilo y peso
        --}}
        {{#unless (eq system.category 'extra')}}
        <div class="armor-row armor-row-equip">

            <div class="armor-field">
                <label for="system.vigor"
                    title="Valor mínimo de Vigor necesario para equipar">V
                    (Vigor)</label>
                <input name="system.vigor" type="number"
                    value="{{system.vigor}}" min="0" />
            </div>

            {{!-- Rota: marcador booleano del estado de la armadura. --}}
            <div class="armor-field armor-field-broken">
                <label for="system.broken"
                    title="Marca si la armadura esta rota">Rota</label>
                <input name="system.broken" type="checkbox"
                    {{#if system.broken}}checked{{/if}} />
            </div>

            {{!-- Sigilo: marcador booleano (checkbox) indicando penalización
            --}}
            {{#unless (eq system.category 'escudo')}}
            <div class="armor-field armor-field-stealth">
                <label for="system.stealth"
                    title="Marca si la armadura penaliza el sigilo">Sigilo</label>
                <input name="system.stealth" type="checkbox"
                    {{#if system.stealth}}checked{{/if}} />
            </div>
            {{/unless}}

            <div class="armor-field">
                <label for="system.weight">Peso</label>
                <input name="system.weight" type="number"
                    value="{{system.weight}}"
                    min="0" step="0.1" />
            </div>

        </div>
        {{/unless}}

        {{!-- Descripción de la armadura --}}
        <div class="armor-field armor-field-description">
            <label for="system.description">Descripción</label>
            <textarea name="system.description"
                placeholder="Describe la armadura">{{system.description}}</textarea>
        </div>

    </section>

</form>
