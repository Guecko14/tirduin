<form class="{{cssClass}} weapon-item-sheet" autocomplete="off">

    {{!-- Panel principal de edición del arma --}}
    <section class="weapon-sheet-panel">

        {{!-- Cabecera con imagen editable y nombre del arma --}}
        <div class="weapon-header-row">
            <img
                class="weapon-image-picker"
                src="{{item.img}}"
                data-edit="img"
                title="{{item.name}}" />

            <div class="weapon-field weapon-field-name">
                <label for="name">Nombre</label>
                <input name="name" type="text" value="{{item.name}}"
                    placeholder="Nombre del arma" />
            </div>
        </div>

        {{!-- Fila de selectores: categoría y subcategoría --}}
        <div class="weapon-row weapon-row-categories">

            <div class="weapon-field">
                <label for="system.category">Categoría</label>
                <select name="system.category">
                    <option value="simple" {{#if (eq system.category
                        'simple')}}selected{{/if}}>Simple</option>
                    <option value="marcial" {{#if (eq system.category
                        'marcial')}}selected{{/if}}>Marcial</option>
                    <option value="magica" {{#if (eq system.category
                        'magica')}}selected{{/if}}>Mágica</option>
                </select>
            </div>

            <div class="weapon-field">
                <label for="system.subcategory">Subcategoría</label>
                <select name="system.subcategory">
                    <option value="melee" {{#if (eq system.subcategory
                        'melee')}}selected{{/if}}>Melee</option>
                    <option value="distancia" {{#if (eq system.subcategory
                        'distancia')}}selected{{/if}}>A distancia</option>
                </select>
            </div>

        </div>

        {{!-- Fila de datos de combate: dado de daño, alcance, grip --}}
        <div class="weapon-row weapon-row-combat">

            <div class="weapon-field">
                <label for="system.damageDie">Dado de daño</label>
                <input name="system.damageDie" type="text"
                    value="{{system.damageDie}}"
                    placeholder="1d6" />
            </div>

            <div class="weapon-field">
                <label for="system.damageType">Tipo daño 1</label>
                <select name="system.damageType">
                    {{#each config.damageTypes as |label key|}}
                    <option value="{{key}}"
                        {{#if (eq ../system.damageType key)}}selected{{/if}}>
                        {{localize label}}
                    </option>
                    {{/each}}
                </select>
            </div>

            <div class="weapon-field">
                <label for="system.damageDie2">Dado daño 2</label>
                <input name="system.damageDie2" type="text"
                    value="{{system.damageDie2}}"
                    placeholder="(opcional)" />
            </div>

            <div class="weapon-field">
                <label for="system.damageType2">Tipo daño 2</label>
                <select name="system.damageType2">
                    <option value {{#unless
                        system.damageType2}}selected{{/unless}}>— Ninguno
                        —</option>
                    {{#each config.damageTypes as |label key|}}
                    <option value="{{key}}"
                        {{#if (eq ../system.damageType2 key)}}selected{{/if}}>
                        {{localize label}}
                    </option>
                    {{/each}}
                </select>
            </div>

            <div class="weapon-field">
                <label for="system.range">Alcance</label>
                <input name="system.range" type="text"
                    value="{{system.range}}"
                    placeholder="5 ft / Toque / 20/60" />
            </div>

            {{#if (eq system.subcategory 'distancia')}}
            <div class="weapon-field">
                <label for="system.projectiles">Proyectiles</label>
                <input name="system.projectiles" type="number"
                    value="{{system.projectiles}}" min="0" step="1"
                    data-dtype="Number" />
            </div>
            {{/if}}

            <div class="weapon-field">
                <label for="system.grip">Grip</label>
                <select name="system.grip">
                    <option value="1" {{#if (eq system.grip
                        '1')}}selected{{/if}}>1 mano</option>
                    <option value="2" {{#if (eq system.grip
                        '2')}}selected{{/if}}>2 manos</option>
                </select>
            </div>

            <div class="weapon-field">
                <label for="system.proficiency">Competencia</label>
                <select name="system.proficiency">
                    <option value="0" {{#if (eq system.proficiency
                        0)}}selected{{/if}}>—</option>
                    <option value="1" {{#if (eq system.proficiency
                        1)}}selected{{/if}}>Basica</option>
                    <option value="2" {{#if (eq system.proficiency
                        2)}}selected{{/if}}>Intermedia</option>
                    <option value="3" {{#if (eq system.proficiency
                        3)}}selected{{/if}}>Avanzada</option>
                    <option value="4" {{#if (eq system.proficiency
                        4)}}selected{{/if}}>Experta</option>
                    <option value="5" {{#if (eq system.proficiency
                        5)}}selected{{/if}}>Maestra</option>
                </select>
            </div>

            <div class="weapon-field">
                <label for="system.weight">Peso</label>
                <input name="system.weight" type="number"
                    value="{{system.weight}}" min="0" step="0.1" />
            </div>

        </div>

        {{!-- Propiedades especiales (texto libre, a expandir en el futuro) --}}
        <div class="weapon-field weapon-field-properties">
            <label for="system.properties">Propiedades</label>
            <input name="system.properties" type="text"
                value="{{system.properties}}"
                placeholder="(próximamente)" />
        </div>

        {{!-- Descripción larga del arma --}}
        <div class="weapon-field weapon-field-description">
            <label for="system.description">Descripción</label>
            <textarea name="system.description"
                placeholder="Describe el arma">{{system.description}}</textarea>
        </div>

    </section>

</form>
