<form class="{{cssClass}} tirduin {{actor.type}} flexcol" autocomplete="off">
    <style>
        /* Base visual del contenedor de botin. */
        .loot-sheet {
            padding: 10px;
            color: #f2e5c8;
            background:
                radial-gradient(120% 90% at 0% 0%, rgba(191, 144, 54, 0.2) 0%, rgba(0, 0, 0, 0) 50%),
                radial-gradient(120% 90% at 100% 0%, rgba(123, 74, 22, 0.15) 0%, rgba(0, 0, 0, 0) 48%),
                #12100d;
        }

        /* Cabecera decorativa para diferenciar visualmente del resto de sheets. */
        .loot-sheet .loot-banner {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 10px;
            padding: 8px 10px;
            border: 1px solid #6f5120;
            border-radius: 8px;
            background: linear-gradient(180deg, #2f2313 0%, #1a130b 100%);
        }

        /* Icono circular del banner. */
        .loot-sheet .loot-banner-icon {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 34px;
            height: 34px;
            border-radius: 50%;
            border: 1px solid #9c7334;
            background: #2a1d0f;
            color: #e0b76a;
        }

        /* Titulo y subtitulo del banner. */
        .loot-sheet .loot-banner-text h1 {
            margin: 0;
            border: 0;
            color: #f0d49a;
            font-size: 1.05rem;
            line-height: 1.1;
        }

        .loot-sheet .loot-banner-text p {
            margin: 1px 0 0;
            font-size: 0.75rem;
            color: #c9ad7b;
        }

        /* Tarjetas base de estadisticas/secciones/listado. */
        .loot-sheet .loot-stat,
        .loot-sheet .loot-items-section,
        .loot-sheet .loot-item-row {
            background: #17130e;
            border: 1px solid #4e3a1d;
            border-radius: 6px;
        }

        /* Fila de monedas en una sola linea (oro/plata/cobre). */
        .loot-sheet .loot-money-row {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 8px;
        }

        .loot-sheet .loot-stat {
            padding: 6px;
        }

        .loot-sheet .loot-stat label {
            display: block;
            margin-bottom: 2px;
            color: #cfb58a;
            font-size: 12px;
        }

        .loot-sheet .loot-stat input {
            width: 100%;
            background: #0f0c09;
            border: 1px solid #664f2a;
            color: #f3e3bf;
            border-radius: 4px;
            text-align: center;
        }

        /* Estilo de botones de creacion de objetos del botin. */
        .loot-sheet .loot-item-create-buttons a {
            border: 1px solid #74572a;
            border-radius: 4px;
            padding: 3px 6px;
            color: #e5c485;
            background: linear-gradient(180deg, #2c2112 0%, #1b140c 100%);
        }

        /* Lista compacta de items del botin, una fila por item. */
        .loot-sheet .loot-item-list {
            list-style: none;
            margin: 0;
            padding: 0;
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .loot-sheet .loot-item-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 8px;
            padding: 6px 8px;
            white-space: nowrap;
        }

        /* Bloque izquierdo de cada fila: icono + nombre + tipo. */
        .loot-sheet .loot-item-name {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            min-width: 0;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .loot-sheet .loot-item-name span {
            overflow: hidden;
            text-overflow: ellipsis;
        }

        /* Bloque derecho de cada fila: controles editar/eliminar. */
        .loot-sheet .loot-item-controls {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            flex: 0 0 auto;
        }
    </style>

    <section class="sheet-body loot-sheet">

        {{!-- Banner de identidad de la hoja de botin. --}}
        <div class="loot-banner">
            <span class="loot-banner-icon"><i
                    class="fas fa-box-open"></i></span>
            <div class="loot-banner-text">
                <h1>Botín</h1>
                <p>Contenedor de objetos y dinero</p>
            </div>
        </div>

        {{!-- Cabecera con imagen, nombre del contenedor y monedas. --}}
        <header class="loot-header">
            <div class="loot-portrait">
                <img class="profile-img" src="{{actor.img}}" data-edit="img"
                    title="{{actor.name}}" />
            </div>

            <div class="loot-header-stats">
                <div class="loot-name-row">
                    <div class="loot-stat loot-name-field">
                        <label for="name">Nombre</label>
                        <input name="name" type="text" value="{{actor.name}}"
                            placeholder="Nombre del botin" />
                    </div>
                </div>

                {{!-- Dinero del botin en una sola fila. --}}
                <div class="loot-money-row">
                    <div class="loot-stat">
                        <label for="system.money.gold">Oro</label>
                        <input type="number" name="system.money.gold"
                            value="{{system.money.gold}}" min="0"
                            data-dtype="Number" />
                    </div>
                    <div class="loot-stat">
                        <label for="system.money.silver">Plata</label>
                        <input type="number" name="system.money.silver"
                            value="{{system.money.silver}}" min="0"
                            data-dtype="Number" />
                    </div>
                    <div class="loot-stat">
                        <label for="system.money.copper">Cobre</label>
                        <input type="number" name="system.money.copper"
                            value="{{system.money.copper}}" min="0"
                            data-dtype="Number" />
                    </div>
                </div>
            </div>
        </header>

        {{!-- Seccion de inventario del botin. --}}
        <section class="loot-items-section">
            <div class="loot-items-header">
                <h2>Objetos</h2>
                {{!-- Solo se permiten tipos de objeto utiles para botin. --}}
                <div class="loot-item-create-buttons">
                    <a class="item-create" data-type="item"
                        title="Nuevo objeto"><i class="fas fa-plus"></i>
                        Objeto</a>
                    <a class="item-create" data-type="weapon"
                        title="Nueva arma"><i class="fas fa-plus"></i> Arma</a>
                    <a class="item-create" data-type="armor"
                        title="Nueva armadura"><i class="fas fa-plus"></i>
                        Armadura</a>
                </div>
            </div>

            {{!-- Lista de items existentes. Cada fila es clicable para tirar
            formula. --}}
            {{#if lootItems.length}}
            <ul class="loot-item-list">
                {{#each lootItems as |item|}}
                <li class="loot-item-row" data-item-id="{{item._id}}">
                    <div class="loot-item-name">
                        <img src="{{item.img}}" alt="{{item.name}}" width="24"
                            height="24" />
                        <span>{{item.name}}</span>
                        <small>({{item.type}})</small>
                    </div>
                    <div class="loot-item-controls">
                        <a class="item-edit" title="Editar"><i
                                class="fas fa-edit"></i></a>
                        <a class="item-delete" title="Eliminar"><i
                                class="fas fa-trash"></i></a>
                    </div>
                </li>
                {{/each}}
            </ul>
            {{else}}
            <p class="loot-empty">No hay objetos en este botin.</p>
            {{/if}}
        </section>

    </section>
</form>
