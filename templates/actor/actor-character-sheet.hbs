<form class="{{cssClass}} {{actor.type}} flexcol" autocomplete="off">

  <section class="sheet-body character">

    <header class="npc-header">
      <div class="npc-portrait">
        <img class="profile-img" src="{{actor.img}}" data-edit="img"
          title="{{actor.name}}" height="100" width="100" />
      </div>

      <div class="npc-header-stats">
        <div class="character-identity-row">
          <div class="npc-stat character-name-field">
            <label for="name">{{localize
              "TIRDUIN_RPS.CharacterSheet.Name"}}</label>
            <input name="name" type="text" value="{{actor.name}}"
              placeholder="{{localize "TIRDUIN_RPS.CharacterSheet.Name"}}" />
          </div>

          <div class="npc-stat character-level-field">
            <label for="system.attributes.level.value">{{localize
              "TIRDUIN_RPS.attributes.level.long"}}</label>
            <input type="number" name="system.attributes.level.value"
              value="{{system.attributes.level.value}}" min="1" max="10"
              onkeyup="if(value<1) value=1; if(value>10) value=10;"
              data-dtype="Number" />
          </div>
        </div>

        <div class="character-meta-row">
          <div class="character-meta-field npc-stat">
            <label for="system.details.race">{{localize
              "TIRDUIN_RPS.CharacterSheet.Race"}}</label>
            <input type="text" name="system.details.race"
              value="{{system.details.race}}"
              placeholder="{{localize "TIRDUIN_RPS.CharacterSheet.Race"}}" />
          </div>
          <div class="character-meta-field npc-stat">
            <label for="system.details.className">{{localize
              "TIRDUIN_RPS.CharacterSheet.Class"}}</label>
            <select name="system.details.className" class="sheet-skill-select">
              <option value="combatiente" {{#if (eq system.details.className
                'combatiente')}}selected{{/if}}>{{localize
                "TIRDUIN_RPS.CharacterSheet.ClassOptions.Combatiente"}}</option>
              <option value="especialista" {{#if (eq system.details.className
                'especialista')}}selected{{/if}}>{{localize
                "TIRDUIN_RPS.CharacterSheet.ClassOptions.Especialista"}}</option>
              <option value="canalizador" {{#if (eq system.details.className
                'canalizador')}}selected{{/if}}>{{localize
                "TIRDUIN_RPS.CharacterSheet.ClassOptions.Canalizador"}}</option>
            </select>
          </div>
          <div class="character-meta-field npc-stat">
            <label for="system.details.background">{{localize
              "TIRDUIN_RPS.CharacterSheet.Background"}}</label>
            <input type="text" name="system.details.background"
              value="{{system.details.background}}"
              placeholder="{{localize "TIRDUIN_RPS.CharacterSheet.Background"}}" />
          </div>
        </div>

        <div class="npc-main">
          <div class="npc-stat">
            <label for="system.health.value">{{localize
              "TIRDUIN_RPS.CharacterSheet.HitPoints"}}</label>
            <div class="hp-row">
              <input type="number" name="system.health.value"
                value="{{system.health.value}}" min="0"
                onkeyup="if(value<0) value=0" data-dtype="Number" />
              <span>/</span>
              <input type="number" name="system.health.max"
                value="{{system.health.max}}" min="0"
                onkeyup="if(value<0) value=0" data-dtype="Number" />
              <span>+</span>
              <input type="number" name="system.health.temp"
                value="{{system.health.temp}}" min="0"
                onkeyup="if(value<0) value=0" data-dtype="Number"
                placeholder="{{localize "TIRDUIN_RPS.CharacterSheet.TempShort"}}"
                title="{{localize "TIRDUIN_RPS.CharacterSheet.TempHitPoints"}}" />
            </div>
          </div>

          <div class="npc-stat">
            <label for="system.attributes.armorClass.value">{{localize
              "TIRDUIN_RPS.attributes.armorClass.long"}}</label>
            <input type="number" name="system.attributes.armorClass.value"
              value="{{system.attributes.armorClass.value}}" min="0"
              onkeyup="if(value<0) value=0" data-dtype="Number" />
          </div>

          <div class="npc-stat">
            <label for="system.attributes.speed.value">{{localize
              "TIRDUIN_RPS.attributes.speed.long"}}</label>
            <input type="number" name="system.attributes.speed.value"
              value="{{system.attributes.speed.value}}" min="0"
              onkeyup="if(value<0) value=0" data-dtype="Number" readonly />
          </div>

          <div class="npc-stat">
            <label for="system.attributes.fatigue.value">{{localize
              "TIRDUIN_RPS.AlteredState.fatigue.label"}}</label>
            <select name="system.attributes.fatigue.value"
              class="sheet-skill-select">
              <option value="0" {{#if (eq system.attributes.fatigue.value
                0)}}selected{{/if}}>0</option>
              <option value="1" {{#if (eq system.attributes.fatigue.value
                1)}}selected{{/if}}>1</option>
              <option value="2" {{#if (eq system.attributes.fatigue.value
                2)}}selected{{/if}}>2</option>
              <option value="3" {{#if (eq system.attributes.fatigue.value
                3)}}selected{{/if}}>3</option>
              <option value="4" {{#if (eq system.attributes.fatigue.value
                4)}}selected{{/if}}>4</option>
              <option value="5" {{#if (eq system.attributes.fatigue.value
                5)}}selected{{/if}}>{{localize
                "TIRDUIN_RPS.CharacterSheet.FatigueDeath"}}</option>
            </select>
          </div>
        </div>
      </div>
    </header>

    <div class="npc-attributes">
      <h2>{{localize "TIRDUIN_RPS.CharacterSheet.Abilities"}}</h2>
      <div class="attr-row">
        {{#each system.abilities as |ability key|}}
        <div class="attr-box">
          <label for="system.abilities.{{key}}.value"
            class="resource-label rollable"
            data-roll="1d20+{{ability.rollMod}}"
            data-label="{{localize (lookup @root.config.abilities key)}}">{{localize
            (lookup @root.config.abilities key)}}</label>
          <input type="number" name="system.abilities.{{key}}.value"
            value="{{ability.value}}" min="-5" max="5"
            onkeyup="if(value<-5) value=-5; if(value>5) value=5;"
            data-dtype="Number" />
          <span class="ability-mod rollable"
            data-roll="1d20+{{ability.rollMod}}"
            data-label="{{localize (lookup @root.config.abilities key)}}">{{numberFormat
            ability.rollMod decimals=0 sign=true}}</span>
        </div>
        {{/each}}
      </div>
    </div>
    
    <div class="saving-throws">
      <h2>{{localize "TIRDUIN_RPS.CharacterSheet.SavingThrows"}}</h2>
      <div class="saving-throws-row">
        <div class="saving-throw-box rollable"
          data-roll="1d20+{{system.saves.fortaleza.value}}"
          data-label="{{localize "TIRDUIN_RPS.CharacterSheet.Saves.Fortaleza"}}">
          <span class="saving-throw-name">{{localize
            "TIRDUIN_RPS.CharacterSheet.Saves.Fortaleza"}}</span>
          <span class="saving-throw-value">{{numberFormat
            system.saves.fortaleza.value sign=true}}</span>
        </div>
        <div class="saving-throw-box rollable"
          data-roll="1d20+{{system.saves.reflejos.value}}"
          data-label="{{localize "TIRDUIN_RPS.CharacterSheet.Saves.Reflejos"}}">
          <span class="saving-throw-name">{{localize
            "TIRDUIN_RPS.CharacterSheet.Saves.Reflejos"}}</span>
          <span class="saving-throw-value">{{numberFormat
            system.saves.reflejos.value sign=true}}</span>
        </div>
        <div class="saving-throw-box rollable"
          data-roll="1d20+{{system.saves.voluntad.value}}"
          data-label="{{localize "TIRDUIN_RPS.CharacterSheet.Saves.Voluntad"}}">
          <span class="saving-throw-name">{{localize
            "TIRDUIN_RPS.CharacterSheet.Saves.Voluntad"}}</span>
          <span class="saving-throw-value">{{numberFormat
            system.saves.voluntad.value sign=true}}</span>
        </div>
      </div>
    </div>

    <div class="resource-pips-row hope-section">
      <div class="npc-stat resource-stat">
        <label>{{localize "TIRDUIN_RPS.CharacterSheet.Resources.Hope"}}</label>
        <div class="resource-pips resource-pips--hope"
          aria-label="{{localize "TIRDUIN_RPS.CharacterSheet.Resources.HopeCurrent"}}">
          {{#each hopePips as |pip|}}
          <button type="button"
            class="resource-pip {{#if pip.filled}}is-filled{{/if}}"
            data-value="{{pip.value}}"
            data-current-value="{{pip.currentValue}}"
            data-resource-path="{{pip.path}}"
            data-max-path="{{pip.maxPath}}"
            data-max-value="{{pip.max}}"
            title="{{localize "TIRDUIN_RPS.CharacterSheet.Resources.Hope"}}
            {{pip.value}} {{localize "TIRDUIN_RPS.CharacterSheet.Of"}}
            {{pip.max}}"></button>
          {{/each}}
        </div>
      </div>

      <div class="npc-stat resource-stat">
        <label>{{localize
          "TIRDUIN_RPS.CharacterSheet.Resources.Stress"}}</label>
        <div class="resource-pips resource-pips--stress"
          aria-label="{{localize "TIRDUIN_RPS.CharacterSheet.Resources.StressCurrent"}}">
          {{#each stressPips as |pip|}}
          <button type="button"
            class="resource-pip {{#if pip.filled}}is-filled{{/if}}"
            data-value="{{pip.value}}"
            data-current-value="{{pip.currentValue}}"
            data-resource-path="{{pip.path}}"
            data-max-path="{{pip.maxPath}}"
            data-max-value="{{pip.max}}"
            title="{{localize "TIRDUIN_RPS.CharacterSheet.Resources.Stress"}}
            {{pip.value}} {{localize "TIRDUIN_RPS.CharacterSheet.Of"}}
            {{pip.max}}"></button>
          {{/each}}
        </div>
      </div>

      <div class="npc-stat resource-stat">
        <label>{{localize "TIRDUIN_RPS.CharacterSheet.Resources.Luck"}}</label>
        <div class="resource-pips"
          aria-label="{{localize "TIRDUIN_RPS.CharacterSheet.Resources.LuckCurrent"}}">
          {{#each luckPips as |pip|}}
          <button type="button"
            class="resource-pip {{#if pip.filled}}is-filled{{/if}}"
            data-value="{{pip.value}}"
            data-current-value="{{pip.currentValue}}"
            data-resource-path="{{pip.path}}"
            data-max-path="{{pip.maxPath}}"
            data-max-value="{{pip.max}}"
            title="{{localize "TIRDUIN_RPS.CharacterSheet.Resources.Luck"}}
            {{pip.value}} {{localize "TIRDUIN_RPS.CharacterSheet.Of"}}
            {{pip.max}}"></button>
          {{/each}}
        </div>
      </div>
    </div>

    <div class="death-roll-section">
      <h3>{{localize "TIRDUIN_RPS.CharacterSheet.DeathRoll"}}</h3>
      <div class="death-roll-container">
        <button type="button" class="death-roll-btn"
          title="{{localize "TIRDUIN_RPS.CharacterSheet.DeathRoll"}}">
          <i class="fas fa-dice-d20"></i>
        </button>
        <div class="death-roll-group">
          <label>{{localize
            "TIRDUIN_RPS.CharacterSheet.Resources.Hope"}}</label>
          <div class="resource-pips resource-pips--hope">
            {{#each deathRollHopePips as |pip|}}
            <button type="button"
              class="resource-pip {{#if pip.filled}}is-filled{{/if}}"
              data-value="{{pip.value}}"
              data-current-value="{{pip.currentValue}}"
              data-resource-path="{{pip.path}}"
              data-max-path="{{pip.maxPath}}"
              data-max-value="{{pip.max}}"
              title="{{localize "TIRDUIN_RPS.CharacterSheet.Resources.Hope"}}
              {{pip.value}} {{localize "TIRDUIN_RPS.CharacterSheet.Of"}}
              {{pip.max}}"></button>
            {{/each}}
          </div>
        </div>
        <div class="death-roll-group">
          <label>{{localize "TIRDUIN_RPS.CharacterSheet.DeathRollFear"}}</label>
          <div class="resource-pips resource-pips--fear">
            {{#each deathRollFearPips as |pip|}}
            <button type="button"
              class="resource-pip {{#if pip.filled}}is-filled{{/if}}"
              data-value="{{pip.value}}"
              data-current-value="{{pip.currentValue}}"
              data-resource-path="{{pip.path}}"
              data-max-path="{{pip.maxPath}}"
              data-max-value="{{pip.max}}"
              title="{{localize "TIRDUIN_RPS.CharacterSheet.DeathRollFear"}}
              {{pip.value}} {{localize "TIRDUIN_RPS.CharacterSheet.Of"}}
              {{pip.max}}"></button>
            {{/each}}
          </div>
        </div>
      </div>
    </div>

    <div class="tabs-layout">
      <nav class="sheet-tabs tabs" data-group="primary">
        <a class="item active" data-tab="skills">{{localize
          "TIRDUIN_RPS.CharacterSheet.Tabs.Skills"}}</a>
        <a class="item" data-tab="features">{{localize
          "TIRDUIN_RPS.CharacterSheet.Tabs.Features"}}</a>
        <a class="item" data-tab="items">{{localize
          "TIRDUIN_RPS.CharacterSheet.Tabs.Items"}}</a>
        <a class="item" data-tab="spells">{{localize
          "TIRDUIN_RPS.CharacterSheet.Tabs.Spells"}}</a>
      </nav>

      <div class="tabs-content">
        <div class="tab skills active" data-group="primary" data-tab="skills">
          <div class="character-skills npc-skills">
            {{> "systems/tirduin/templates/actor/parts/actor-skills.hbs"}}
          </div>
        </div>

        <div class="tab features" data-group="primary" data-tab="features">
          {{> "systems/tirduin/templates/actor/parts/actor-features.hbs"}}
        </div>

        <div class="tab items" data-group="primary" data-tab="items">
          {{> "systems/tirduin/templates/actor/parts/actor-npc-objects.hbs"}}
        </div>

        <div class="tab spells" data-group="primary" data-tab="spells">
          {{> "systems/tirduin/templates/actor/parts/actor-spells.hbs"}}
        </div>
      </div>
    </div>

  </section>
</form>
