<form class="{{cssClass}} {{actor.type}} flexcol" autocomplete="off">

  <section class="sheet-body character">

    {{!-- Sheet Header --}}
    <header class="npc-header">
      <div class="npc-portrait">
        <img class="profile-img" src="{{actor.img}}" data-edit="img"
          title="{{actor.name}}" height="100" width="100" />
      </div>

      <div class="npc-header-stats">
        <div class="npc-name">
          <input name="name" type="text" value="{{actor.name}}"
            placeholder="Nombre" />
        </div>

        <div class="npc-main">
          <div class="npc-stat">
            <label for="system.health.value">Puntos de Vida</label>
            <div class="hp-row">
              <input type="number" name="system.health.value"
                value="{{system.health.value}}" min="0"
                onkeyup="if(value<0) value=0" data-dtype="Number" />
              <span>/</span>
              <input type="number" name="system.health.max"
                value="{{system.health.max}}" min="0"
                onkeyup="if(value<0) value=0" data-dtype="Number" />
            </div>
          </div>

          <div class="npc-stat">
            <label for="system.power.value">Energia</label>
            <div class="hp-row">
              <input type="number" name="system.power.value"
                value="{{system.power.value}}" min="0"
                onkeyup="if(value<0) value=0" data-dtype="Number" />
              <span>/</span>
              <input type="number" name="system.power.max"
                value="{{system.power.max}}" min="0"
                onkeyup="if(value<0) value=0" data-dtype="Number" readonly />
            </div>
          </div>

          <div class="npc-stat">
            <label for="system.attributes.level.value">Nivel</label>
            <input type="number" name="system.attributes.level.value"
              value="{{system.attributes.level.value}}" min="1" max="10"
              onkeyup="if(value<1) value=1; if(value>10) value=10;"
              data-dtype="Number" />
          </div>

          <div class="npc-stat">
            <label for="system.attributes.armorClass.value">Clase de
              Armadura</label>
            <input type="number" name="system.attributes.armorClass.value"
              value="{{system.attributes.armorClass.value}}" min="0"
              onkeyup="if(value<0) value=0" data-dtype="Number" />
          </div>

          <div class="npc-stat">
            <label for="system.attributes.speed.value">Velocidad</label>
            <input type="number" name="system.attributes.speed.value"
              value="{{system.attributes.speed.value}}" min="0"
              onkeyup="if(value<0) value=0" data-dtype="Number" />
          </div>
        </div>
      </div>
    </header>

    <div class="npc-attributes">
      <h2>Atributos</h2>
      <div class="attr-row">
        {{#each system.abilities as |ability key|}}
        <div class="attr-box">
          <label for="system.abilities.{{key}}.value"
            class="resource-label rollable"
            data-roll="d20+@abilities.{{key}}.mod"
            data-label="{{localize (lookup @root.config.abilities key)}}">{{localize
            (lookup @root.config.abilities key)}}</label>
          <input type="number" name="system.abilities.{{key}}.value"
            value="{{ability.value}}" min="-5" max="5"
            onkeyup="if(value<-5) value=-5; if(value>5) value=5;"
            data-dtype="Number" />
          <span class="ability-mod rollable"
            data-roll="d20+@abilities.{{key}}.mod"
            data-label="{{localize (lookup @root.config.abilities key)}}">{{numberFormat
            ability.mod decimals=0 sign=true}}</span>
        </div>
        {{/each}}
      </div>
    </div>

    {{!-- TABS LAYOUT: sidebar lateral + panel principal del contenido --}}
    <div class="tabs-layout">

      {{!-- Sheet Tab Navigation: orden principal de secciones visibles del
      personaje --}}
      <nav class="sheet-tabs tabs" data-group="primary">
        {{!-- Default tab is specified in actor-sheet.mjs --}}
        <a class="item active" data-tab="skills">Habilidades</a>
        <a class="item" data-tab="features">Dotes</a>
        <a class="item" data-tab="description">Descripción</a>
        <a class="item" data-tab="items">Objetos</a>
        <a class="item" data-tab="spells">Conjuros</a>
        <a class="item" data-tab="effects">Efectos</a>
      </nav>

      {{!-- Contenido de tabs: cada bloque conserva su partial o editor propio
      --}}
      <div class="tabs-content">

        {{!-- Skills Tab --}}
        <div class="tab skills active" data-group="primary" data-tab="skills">
          <div class="character-skills npc-skills">
            {{> "systems/tirduin/templates/actor/parts/actor-skills.hbs"}}
          </div>
        </div>

        {{!-- Owned Features Tab --}}
        <div class="tab features" data-group="primary" data-tab="features">
          <section class="grid grid-3col">
            <aside class="sidebar"></aside>
            <section class="main grid-span-2">
              {{> "systems/tirduin/templates/actor/parts/actor-features.hbs"}}
            </section>
          </section>
        </div>

        {{!-- Biography Tab --}}
        <div class="tab biography description" data-group="primary"
          data-tab="description">
          {{editor enrichedBiography target="system.biography"
          engine="prosemirror" button=true editable=editable}}
        </div>

        {{!-- Owned Items Tab --}}
        <div class="tab items" data-group="primary" data-tab="items">
          {{> "systems/tirduin/templates/actor/parts/actor-npc-objects.hbs"}}
        </div>

        {{!-- Owned Spells Tab --}}
        <div class="tab spells" data-group="primary" data-tab="spells">
          {{> "systems/tirduin/templates/actor/parts/actor-spells.hbs"}}
        </div>

        {{!-- Active Effects Tab --}}
        <div class="tab effects" data-group="primary" data-tab="effects">
          {{> "systems/tirduin/templates/actor/parts/actor-effects.hbs"}}
        </div>

      </div>

    </div><!-- /.tabs-layout -->

  </section>
</form>
