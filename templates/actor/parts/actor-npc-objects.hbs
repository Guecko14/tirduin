<div class="npc-objects">

    <div class="npc-slots-summary">
        <div class="npc-slots-values">
            <span class="npc-slots-label">Slots</span>
            <span class="npc-slots-current">{{npcSlots.current}}</span>
            <span class="npc-slots-separator">/</span>
            <span class="npc-slots-capacity">{{npcSlots.capacity}}</span>
        </div>
        <div class="npc-slots-extra">
            <label for="system.attributes.slotsExtra.value">Contenedores</label>
            <input type="number" name="system.attributes.slotsExtra.value"
                value="{{system.attributes.slotsExtra.value}}" min="0" />
        </div>
    </div>

    <div class="npc-money-summary">
        <div class="npc-money-label">Monedas</div>
        <div class="npc-money-fields">
            <label>
                Oro
                <input type="number" name="system.money.gold"
                    value="{{system.money.gold}}" min="0" />
            </label>
            <label>
                Plata
                <input type="number" name="system.money.silver"
                    value="{{system.money.silver}}" min="0" />
            </label>
            <label>
                Cobre
                <input type="number" name="system.money.copper"
                    value="{{system.money.copper}}" min="0" />
            </label>
        </div>
    </div>

    {{!-- ================================================================
    SECCIÓN: ARMAS
    Items de tipo "weapon" con categoría, subcategoría, dado de daño y alcance.
    ================================================================ --}}
    <div class="npc-objects-section">

        <div class="npc-objects-header">
            <h2>Armas</h2>
            {{!-- Botón de creación de arma --}}
            <a class="item-create npc-object-add-btn" data-type="weapon"
                title="Nueva arma">
                <i class="fas fa-plus"></i> Nueva
            </a>
        </div>

        {{#if npcWeapons.length}}
        <ul class="npc-object-list npc-weapon-list">

            {{!-- Cabecera de columnas de la tabla de armas --}}
            <li class="npc-weapon-header npc-object-list-header">
                <span class="npc-weapon-col-name">Nombre</span>
                <span class="npc-weapon-col-cat">Cat.</span>
                <span class="npc-weapon-col-sub">Subtipo</span>
                <span class="npc-weapon-col-damage">Daños</span>
                <span class="npc-weapon-col-range">Alcance</span>
                <span class="npc-weapon-col-grip">Grip</span>
                <span class="npc-weapon-col-controls"></span>
            </li>

            {{#each npcWeapons as |weapon|}}
            <li class="npc-object-item npc-weapon-item"
                data-item-id="{{weapon._id}}">
                <span class="npc-weapon-col-name">{{weapon.name}}</span>
                <span
                    class="npc-weapon-col-cat">{{weaponCategoryLabel
                    weapon.system.category}}</span>
                <span
                    class="npc-weapon-col-sub">{{weaponSubcategoryLabel
                    weapon.system.subcategory}}</span>
                <span class="npc-weapon-col-damage">
                    {{weapon.system.damageDie}}
                    ({{damageTypeAbbr weapon.system.damageType}})
                    {{#if weapon.system.damageDie2}}
                    / {{weapon.system.damageDie2}}
                    ({{damageTypeAbbr weapon.system.damageType2}})
                    {{/if}}
                </span>
                <span
                    class="npc-weapon-col-range">{{weapon.system.range}}</span>
                <span class="npc-weapon-col-grip">{{weapon.system.grip}}M</span>
                <div class="npc-object-controls npc-weapon-col-controls">
                    <a
                        class="weapon-action-toggle {{#if (isTrue weapon.system.actionEnabled)}}is-enabled{{/if}}"
                        title="{{#if (isTrue weapon.system.actionEnabled)}}Quitar de Acciones{{else}}Añadir a Acciones{{/if}}">
                        <i class="fas fa-bolt"></i>
                    </a>
                    <a class="item-edit" title="Editar"><i
                            class="fas fa-edit"></i></a>
                    <a class="item-delete" title="Eliminar"><i
                            class="fas fa-trash"></i></a>
                </div>
            </li>
            {{/each}}

        </ul>
        {{else}}
        <p class="npc-objects-empty">No hay armas. Usa «Nueva» para añadir
            una.</p>
        {{/if}}

    </div>

    {{!-- ================================================================
    SECCIÓN: ARMADURAS
    Items de tipo "armor" con CA, VD, RA, Resistencia, Vigor y sigilo.
    ================================================================ --}}
    <div class="npc-objects-section">

        <div class="npc-objects-header">
            <h2>Armaduras</h2>
            {{!-- Botón de creación de armadura --}}
            <a class="item-create npc-object-add-btn" data-type="armor"
                title="Nueva armadura">
                <i class="fas fa-plus"></i> Nueva
            </a>
        </div>

        {{#if npcArmors.length}}
        <ul class="npc-object-list npc-armor-list">

            {{!-- Cabecera de columnas de la tabla de armaduras --}}
            <li class="npc-armor-header npc-object-list-header">
                <span class="npc-armor-col-name">Nombre</span>
                <span class="npc-armor-col-cat">Cat.</span>
                <span class="npc-armor-col-ca">CA</span>
                <span class="npc-armor-col-ca-broken">CA rota</span>
                <span class="npc-armor-col-vd">VD</span>
                <span class="npc-armor-col-ra">RA</span>
                <span class="npc-armor-col-resistance">R</span>
                <span class="npc-armor-col-vigor">V</span>
                <span class="npc-armor-col-broken">Rota</span>
                <span class="npc-armor-col-stealth">Sigilo</span>
                <span class="npc-armor-col-controls"></span>
            </li>

            {{#each npcArmors as |armor|}}
            <li class="npc-object-item npc-armor-item"
                data-item-id="{{armor._id}}">
                <span class="npc-armor-col-name">{{armor.name}}</span>
                <span class="npc-armor-col-cat">{{armorCategoryLabel
                    armor.system.category}}</span>
                <span class="npc-armor-col-ca">
                    {{#if (or (eq armor.system.category 'escudo') (eq
                    armor.system.category 'extra'))}}
                    +{{armor.system.bonus}}
                    {{else}}
                    {{armor.system.ca}} ({{armor.system.maxAgility}})
                    {{/if}}
                </span>
                <span
                    class="npc-armor-col-ca-broken">
                    {{#if (eq armor.system.category 'extra')}}

                    {{else if (eq armor.system.category 'escudo')}}

                    {{else}}
                    {{armor.system.caBroken}}
                    ({{armor.system.maxAgilityBroken}})
                    {{/if}}
                </span>
                {{#if (eq armor.system.category 'extra')}}
                <span class="npc-armor-col-vd"></span>
                {{else}}
                <span class="npc-armor-col-vd npc-armor-roll-vd"
                    title="Tirar VD y aplicar desgaste de RA">{{armor.system.vd}}</span>
                {{/if}}
                {{!-- Muestra RA actual / RA máxima para ver el desgaste de un
                vistazo --}}
                <span class="npc-armor-col-ra">{{#if (eq armor.system.category
                    'extra')}}{{else}}{{armor.system.raCurrent}}/{{armor.system.ra}}{{/if}}</span>
                <span
                    class="npc-armor-col-resistance">{{#if (eq
                    armor.system.category
                    'escudo')}}{{else}}{{#if (eq armor.system.category
                    'extra')}}{{else}}{{armorResistanceSummary
                    armor.system}}{{/if}}{{/if}}</span>
                <span class="npc-armor-col-vigor">{{#if (eq
                    armor.system.category
                    'extra')}}{{else}}{{armor.system.vigor}}{{/if}}</span>
                <span class="npc-armor-col-broken">
                    {{#if (eq armor.system.category 'extra')}}

                    {{else if armor.system.broken}}
                    <i class="fas fa-shield-halved" title="Armadura rota"></i>
                    {{else}}
                    —
                    {{/if}}
                </span>
                {{!-- Icono de escudo tachado si la armadura penaliza el sigilo
                --}}
                <span class="npc-armor-col-stealth">
                    {{#if (or (eq armor.system.category 'escudo') (eq
                    armor.system.category 'extra'))}}

                    {{else}}
                    {{#if armor.system.stealth}}
                    <i class="fas fa-eye-slash" title="Penaliza sigilo"></i>
                    {{else}}
                    —
                    {{/if}}
                    {{/if}}
                </span>
                <div class="npc-object-controls npc-armor-col-controls">
                    <a
                        class="armor-equip-toggle {{#if armor.system.equipped}}is-equipped{{/if}}"
                        title="{{#if armor.system.equipped}}Desequipar{{else}}Equipar{{/if}}">
                        <i class="fas fa-shield"></i>
                    </a>
                    <a class="item-edit" title="Editar"><i
                            class="fas fa-edit"></i></a>
                    <a class="item-delete" title="Eliminar"><i
                            class="fas fa-trash"></i></a>
                </div>
            </li>
            {{/each}}

        </ul>
        {{else}}
        <p class="npc-objects-empty">No hay armaduras. Usa «Nueva» para añadir
            una.</p>
        {{/if}}

    </div>

    {{!-- ================================================================
    SECCIÓN: OBJETOS GENÉRICOS
    Items de tipo "item" con sólo nombre y descripción visible en la ficha.
    ================================================================ --}}
    <div class="npc-objects-section">

        <div class="npc-objects-header">
            <h2>Objetos</h2>
            {{!-- Botón de creación de objeto genérico --}}
            <a class="item-create npc-object-add-btn" data-type="item"
                title="Nuevo objeto">
                <i class="fas fa-plus"></i> Nuevo
            </a>
        </div>

        {{#if npcGenericObjects.length}}
        <ul class="npc-object-list">
            {{#each npcGenericObjects as |obj|}}
            <li class="npc-object-item" data-item-id="{{obj._id}}">

                {{!-- Fila principal: nombre del objeto y controles de
                edición/borrado --}}
                <div class="npc-object-main">
                    <span class="npc-object-name">{{obj.name}}</span>
                    <span
                        class="npc-object-quantity">x{{obj.system.quantity}}</span>
                    <div class="npc-object-controls">
                        <a class="item-edit" title="Editar"><i
                                class="fas fa-edit"></i></a>
                        <a class="item-delete" title="Eliminar"><i
                                class="fas fa-trash"></i></a>
                    </div>
                </div>

                {{!-- Descripción resumida para consulta rápida sin abrir la
                sheet --}}
                {{#if obj.system.description}}
                <div class="npc-object-desc">{{obj.system.description}}</div>
                {{/if}}

            </li>
            {{/each}}
        </ul>
        {{else}}
        <p class="npc-objects-empty">No hay objetos. Usa «Nuevo» para añadir
            uno.</p>
        {{/if}}

    </div>

</div>
