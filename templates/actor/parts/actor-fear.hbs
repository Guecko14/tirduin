<div class="fear-actions">

  {{!-- Cabecera del tab: titulo del bloque y accion para crear una nueva entrada de miedo --}}
  <div class="fear-actions-header">
    <h2>Acciones de Miedo</h2>
    <a class="item-create fear-add-btn" data-type="feature" data-category="fear" data-cost="0" title="Nueva acción de miedo">
      <i class="fas fa-plus"></i> Nueva
    </a>
  </div>

  {{!-- Listado de acciones ya creadas para este NPC --}}
  {{#if fearActions.length}}
  <ul class="fear-list">
    {{#each fearActions as |action|}}
    <li class="fear-item" data-item-id="{{action._id}}">

      {{!-- Fila principal: coste, nombre y controles de edicion/borrado --}}
      <div class="fear-item-main">
        <span class="fear-cost-badge" title="Coste de Miedo">{{action.system.cost}}</span>
        <span class="fear-name">{{action.name}}</span>
        <div class="fear-controls">
          <a class="item-edit fear-edit" title="Editar"><i class="fas fa-edit"></i></a>
          <a class="item-delete fear-delete" title="Eliminar"><i class="fas fa-trash"></i></a>
        </div>
      </div>

      {{!-- Resumen visible de la descripcion para no abrir la sheet en cada consulta --}}
      {{#if action.system.description}}
      <div class="fear-desc">{{action.system.description}}</div>
      {{/if}}

    </li>
    {{/each}}
  </ul>
  {{else}}
  {{!-- Estado vacio cuando el NPC todavia no tiene acciones de miedo --}}
  <p class="fear-empty">No hay acciones de miedo. Usa «Nueva» para añadir una.</p>
  {{/if}}

</div>
