<div class="npc-objects npc-actions">

    <div class="npc-objects-section">
        <div class="npc-objects-header">
            <h2>Ataques</h2>
            <a class="item-create npc-object-add-btn" data-type="weapon"
                data-action-enabled="true" data-from-actions="true"
                title="Nuevo ataque">
                <i class="fas fa-plus"></i> Nuevo
            </a>
        </div>

        <ul class="npc-object-list">
            {{#each npcWeaponActions as |weapon|}}
            <li class="npc-object-item npc-action-item"
                data-action-kind="weapon" data-item-id="{{weapon._id}}">
                <div class="npc-object-main">
                    <span class="npc-object-name">Atacar con
                        {{weapon.name}}</span>
                    <div class="npc-object-controls">
                        <a class="item-edit" title="Editar"><i
                                class="fas fa-edit"></i></a>
                    </div>
                </div>
            </li>
            {{else}}
            <p class="npc-objects-empty">No hay armas marcadas para
                acciones.</p>
            {{/each}}
        </ul>
    </div>

    <div class="npc-objects-section">
        <div class="npc-objects-header">
            <h2>Paradas de Armadura</h2>
        </div>

        <ul class="npc-object-list">
            {{#each npcArmorActions as |armor|}}
            <li class="npc-object-item npc-action-item" data-action-kind="armor"
                data-item-id="{{armor._id}}">
                <div class="npc-object-main">
                    <span class="npc-object-name">Parar con
                        {{armor.name}}</span>
                    <div class="npc-object-controls">
                        <a class="item-edit" title="Editar"><i
                                class="fas fa-edit"></i></a>
                    </div>
                </div>
            </li>
            {{else}}
            <p class="npc-objects-empty">No hay armaduras equipadas para
                parar.</p>
            {{/each}}
        </ul>
    </div>

    <div class="npc-objects-section">
        <div class="npc-objects-header">
            <h2>Ataques Mágicos</h2>
            <a class="item-create npc-object-add-btn" data-type="feature"
                data-category="magicAction" title="Nuevo ataque magico">
                <i class="fas fa-plus"></i> Nuevo
            </a>
        </div>

        <ul class="npc-object-list">
            {{#each npcMagicActions as |magic|}}
            <li class="npc-object-item npc-action-item" data-action-kind="magic"
                data-item-id="{{magic._id}}">
                <div class="npc-object-main">
                    <span class="npc-object-name">{{magic.name}} (CD
                        {{magic.system.cd}} {{magic.system.saveType}})</span>
                    <div class="npc-object-controls">
                        <a class="item-edit" title="Editar"><i
                                class="fas fa-edit"></i></a>
                        <a class="item-delete" title="Eliminar"><i
                                class="fas fa-trash"></i></a>
                    </div>
                </div>
            </li>
            {{else}}
            <p class="npc-objects-empty">No hay ataques mágicos.</p>
            {{/each}}
        </ul>
    </div>

</div>
