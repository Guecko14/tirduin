<form class="{{cssClass}} {{actor.type}} flexcol" autocomplete="off">
  <section class="sheet-body npc-sheet">

    <header class="npc-header">

      <!-- IMAGEN -->
      <div class="npc-portrait">
        <img class="profile-img"
          src="{{actor.img}}"
          data-edit="img"
          title="{{actor.name}}" />
      </div>

      <!-- INFO PRINCIPAL -->
      <div class="npc-header-stats">

        <div class="npc-name-wrap">
          <div class="npc-identity-fields">
            <div class="npc-stat npc-name">
              <label for="name">Nombre</label>
              <input name="name" type="text" value="{{actor.name}}"
                placeholder="Nombre" />
            </div>
            <div class="npc-stat npc-size-field">
              <label for="system.details.size">{{localize
                "TIRDUIN_RPS.CharacterSheet.Size"}}</label>
              <select name="system.details.size" class="sheet-skill-select">
                <option value="diminuto" {{#if (eq system.details.size
                  'diminuto')}}selected{{/if}}>{{localize
                  "TIRDUIN_RPS.CharacterSheet.SizeOptions.Diminuto"}}</option>
                <option value="pequeno" {{#if (eq system.details.size
                  'pequeno')}}selected{{/if}}>{{localize
                  "TIRDUIN_RPS.CharacterSheet.SizeOptions.Pequeno"}}</option>
                <option value="mediano" {{#if (eq system.details.size
                  'mediano')}}selected{{/if}}>{{localize
                  "TIRDUIN_RPS.CharacterSheet.SizeOptions.Mediano"}}</option>
                <option value="grande" {{#if (eq system.details.size
                  'grande')}}selected{{/if}}>{{localize
                  "TIRDUIN_RPS.CharacterSheet.SizeOptions.Grande"}}</option>
                <option value="enorme" {{#if (eq system.details.size
                  'enorme')}}selected{{/if}}>{{localize
                  "TIRDUIN_RPS.CharacterSheet.SizeOptions.Enorme"}}</option>
                <option value="gargantuesco" {{#if (eq
                  system.details.size
                  'gargantuesco')}}selected{{/if}}>{{localize
                  "TIRDUIN_RPS.CharacterSheet.SizeOptions.Gargantuesco"}}</option>
              </select>
            </div>
          </div>
          <button type="button" class="initiative-roll-btn"
            title="{{localize "TIRDUIN_RPS.CharacterSheet.InitiativeRoll"}}">
            <i class="fas fa-dice-d20"></i>
          </button>
        </div>

        <div class="npc-main">

          <div class="npc-stat">
            <label>PV</label>
            <div class="hp-row">
              <input type="number" name="system.health.value"
                value="{{system.health.value}}" min="0"
                onkeyup="if(value<0) value=0" />
              /
              <input type="number" name="system.health.max"
                value="{{system.health.max}}" min="0"
                onkeyup="if(value<0) value=0" />
            </div>
          </div>

          <div class="npc-stat">
            <label>CA</label>
            <input type="number" name="system.attributes.armorClass.value"
              value="{{system.attributes.armorClass.value}}" min="0"
              onkeyup="if(value<0) value=0" />
          </div>

          <div class="npc-stat">
            <label>{{localize "TIRDUIN_RPS.attributes.speed.long"}}</label>
            <div class="speed-row">
              <input type="number" name="system.attributes.speed.value"
                value="{{system.attributes.speed.value}}" min="0"
                onkeyup="if(value<0) value=0" data-dtype="Number" />
            </div>
          </div>

          <div class="npc-stat">
            <label for="system.attributes.fatigue.value">{{localize
              "TIRDUIN_RPS.AlteredState.fatigue.label"}}</label>
            <select name="system.attributes.fatigue.value"
              class="sheet-skill-select">
              <option value="0" {{#if (eq system.attributes.fatigue.value
                0)}}selected{{/if}}>0</option>
              <option value="1" {{#if (eq system.attributes.fatigue.value
                1)}}selected{{/if}}>1</option>
              <option value="2" {{#if (eq system.attributes.fatigue.value
                2)}}selected{{/if}}>2</option>
              <option value="3" {{#if (eq system.attributes.fatigue.value
                3)}}selected{{/if}}>3</option>
              <option value="4" {{#if (eq system.attributes.fatigue.value
                4)}}selected{{/if}}>4</option>
              <option value="5" {{#if (eq system.attributes.fatigue.value
                5)}}selected{{/if}}>{{localize
                "TIRDUIN_RPS.CharacterSheet.FatigueDeath"}}</option>
            </select>
          </div>

        </div>

      </div>

    </header>

    <!-- ATRIBUTOS -->
    <div class="npc-attributes">
      <h2>Atributos</h2>

      <div class="attr-row">

        {{#each system.abilities as |ability key|}}
        <div class="attr-box">
          <label for="system.abilities.{{key}}.value"
            class="resource-label rollable flexlarge align-left"
            data-roll="1d20+{{ability.rollMod}}"
            data-label="{{localize (lookup @root.config.abilities key)}}">{{localize
            (lookup @root.config.abilities key)}}</label>

          <input type="number"
            name="system.abilities.{{key}}.value"
            value="{{ability.value}}" />

        </div>
        {{/each}}

      </div>
    </div>

    <div class="saving-throws">
      <h2>Salvaciones</h2>
      <div class="saving-throws-row">
        <div class="saving-throw-box rollable"
          data-roll="1d20+{{system.saves.fortaleza.value}}"
          data-label="Fortaleza">
          <span class="saving-throw-name">Fortaleza</span>
          <span class="saving-throw-value">{{numberFormat
            system.saves.fortaleza.value sign=true}}</span>
        </div>
        <div class="saving-throw-box rollable"
          data-roll="1d20+{{system.saves.reflejos.value}}"
          data-label="Reflejos">
          <span class="saving-throw-name">Reflejos</span>
          <span class="saving-throw-value">{{numberFormat
            system.saves.reflejos.value sign=true}}</span>
        </div>
        <div class="saving-throw-box rollable"
          data-roll="1d20+{{system.saves.voluntad.value}}"
          data-label="Voluntad">
          <span class="saving-throw-name">Voluntad</span>
          <span class="saving-throw-value">{{numberFormat
            system.saves.voluntad.value sign=true}}</span>
        </div>
      </div>
    </div>

    <div class="special-actions-block">
      {{> "systems/tirduin/templates/actor/parts/actor-special.hbs"}}
    </div>

    <!-- TABS LAYOUT: contenedor lateral para navegacion y contenido -->
    <div class="tabs-layout">

      <!-- TABS NAVIGATION: accesos rapidos a los bloques editables del NPC -->
      <nav class="sheet-tabs tabs" data-group="npc-sections">
        <a class="item active" data-tab="actions">Acciones</a>
        <a class="item" data-tab="skills">Habilidades</a>
        <a class="item" data-tab="objects">Objetos</a>
        <a class="item" data-tab="spells">Conjuros</a>
      </nav>

      <!-- TABS CONTENT: cada panel se muestra segun el tab activo -->
      <div class="tabs-content">

        <!-- ACCIONES TAB: ataques de arma, parar con armadura y ataques mágicos -->
        <div class="tab active" data-tab="actions">
          {{> "systems/tirduin/templates/actor/parts/actor-npc-actions.hbs"}}
        </div>

        <!-- HABILIDADES TAB -->
        <div class="tab" data-tab="skills">
          <div class="npc-skills">
            {{> "systems/tirduin/templates/actor/parts/actor-skills.hbs"}}
          </div>
        </div>

        <!-- OBJETOS TAB: lista objetos genéricos, armas y armaduras del NPC -->
        <div class="tab" data-tab="objects">
          {{> "systems/tirduin/templates/actor/parts/actor-npc-objects.hbs"}}
        </div>

        <!-- conjuros TAB: lista conjuros NPC -->
        <div class="tab spells" data-group="primary" data-tab="spells">
          {{> "systems/tirduin/templates/actor/parts/actor-spells.hbs"}}
        </div>

      </div>

    </div><!-- /.tabs-layout -->

  </section>
</form>