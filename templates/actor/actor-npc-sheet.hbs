<form class="{{cssClass}} {{actor.type}} flexcol" autocomplete="off">
  <section class="sheet-body npc-sheet">

    <header class="npc-header">

      <!-- IMAGEN -->
      <div class="npc-portrait">
        <img class="profile-img"
          src="{{actor.img}}"
          data-edit="img"
          title="{{actor.name}}" />
      </div>

      <!-- INFO PRINCIPAL -->
      <div class="npc-header-stats">

        <div class="npc-stat npc-name">
          <label for="name">Nombre</label>
          <input name="name" type="text" value="{{actor.name}}"
            placeholder="Nombre" />
        </div>

        <div class="npc-main">

          <div class="npc-stat">
            <label>PV</label>
            <div class="hp-row">
              <input type="number" name="system.health.value"
                value="{{system.health.value}}" min="0"
                onkeyup="if(value<0) value=0" />
              /
              <input type="number" name="system.health.max"
                value="{{system.health.max}}" min="0"
                onkeyup="if(value<0) value=0" />
            </div>
          </div>

          <div class="npc-stat">
            <label>CA</label>
            <input type="number" name="system.attributes.armorClass.value"
              value="{{system.attributes.armorClass.value}}" min="0"
              onkeyup="if(value<0) value=0" />
          </div>

          <div class="npc-stat">
            <label>Velocidad</label>
            <input type="number" name="system.attributes.speed.value"
              value="{{system.attributes.speed.value}}" min="0"
              onkeyup="if(value<0) value=0" />
          </div>

        </div>

      </div>

    </header>

    <!-- ATRIBUTOS -->
    <div class="npc-attributes">
      <h2>Atributos</h2>

      <div class="attr-row">

        {{#each system.abilities as |ability key|}}
        <div class="attr-box">
          <label for="system.abilities.{{key}}.value"
            class="resource-label rollable flexlarge align-left"
            data-roll="d20+{{numberFormat ability.value sign=true}}"
            data-label="{{localize (lookup @root.config.abilities key)}}">{{localize
            (lookup @root.config.abilities key)}}</label>

          <input type="number"
            name="system.abilities.{{key}}.value"
            value="{{ability.value}}"
            min="-5" max="5"
            onkeyup="if(value<-5) value=-5; if(value>5) value=5;" />

        </div>
        {{/each}}

      </div>
    </div>

    <div class="saving-throws">
      <h2>Salvaciones</h2>
      <div class="saving-throws-row">
        <div class="saving-throw-box rollable"
          data-roll="1d20+{{system.saves.fortaleza.value}}"
          data-label="Fortaleza">
          <span class="saving-throw-name">Fortaleza</span>
          <span class="saving-throw-value">{{numberFormat
            system.saves.fortaleza.value sign=true}}</span>
        </div>
        <div class="saving-throw-box rollable"
          data-roll="1d20+{{system.saves.reflejos.value}}"
          data-label="Reflejos">
          <span class="saving-throw-name">Reflejos</span>
          <span class="saving-throw-value">{{numberFormat
            system.saves.reflejos.value sign=true}}</span>
        </div>
        <div class="saving-throw-box rollable"
          data-roll="1d20+{{system.saves.voluntad.value}}"
          data-label="Voluntad">
          <span class="saving-throw-name">Voluntad</span>
          <span class="saving-throw-value">{{numberFormat
            system.saves.voluntad.value sign=true}}</span>
        </div>
      </div>
    </div>

    <!-- TABS LAYOUT: contenedor lateral para navegacion y contenido -->
    <div class="tabs-layout">

      <!-- TABS NAVIGATION: accesos rapidos a los bloques editables del NPC -->
      <nav class="sheet-tabs tabs" data-group="npc-sections">
        <a class="item active" data-tab="actions">Acciones</a>
        <a class="item" data-tab="skills">Habilidades</a>
        <a class="item" data-tab="special">Especial</a>
        <a class="item" data-tab="fear">Miedo</a>
        <a class="item" data-tab="objects">Objetos</a>
      </nav>

      <!-- TABS CONTENT: cada panel se muestra segun el tab activo -->
      <div class="tabs-content">

        <!-- ACCIONES TAB: ataques de arma, parar con armadura y ataques mágicos -->
        <div class="tab active" data-tab="actions">
          {{> "systems/tirduin/templates/actor/parts/actor-npc-actions.hbs"}}
        </div>

        <!-- HABILIDADES TAB -->
        <div class="tab" data-tab="skills">
          <div class="npc-skills">
            {{> "systems/tirduin/templates/actor/parts/actor-skills.hbs"}}
          </div>
        </div>

        <!-- ESPECIALES TAB: lista y gestiona entradas especiales como items del NPC -->
        <div class="tab" data-tab="special">
          {{> "systems/tirduin/templates/actor/parts/actor-special.hbs"}}
        </div>

        <!-- MIEDO TAB: lista y gestiona acciones de miedo como items del NPC -->
        <div class="tab" data-tab="fear">
          {{> "systems/tirduin/templates/actor/parts/actor-fear.hbs"}}
        </div>

        <!-- OBJETOS TAB: lista objetos genéricos, armas y armaduras del NPC -->
        <div class="tab" data-tab="objects">
          {{> "systems/tirduin/templates/actor/parts/actor-npc-objects.hbs"}}
        </div>

      </div>

    </div><!-- /.tabs-layout -->

  </section>
</form>