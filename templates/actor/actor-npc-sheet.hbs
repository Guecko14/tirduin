<form class="{{cssClass}} {{actor.type}} flexcol" autocomplete="off">

  {{!-- Sheet Header --}}
  <header class="sheet-header">
    <img class="profile-img" src="{{actor.img}}" data-edit="img"
      title="{{actor.name}}" height="100" width="100" />
    <div class="header-fields">
      <label class="resource-label">Nombre</label>
      <h1 class="charname"><input name="name" type="text" value="{{actor.name}}"
          placeholder="Name" /></h1>
      {{!-- The grid classes are defined in scss/global/_grid.scss. To use,
      use both the "grid" and "grid-Ncol" class where "N" can be any number
      from 1 to 12 and will create that number of columns. --}}
      <div class="resources grid grid-3col">

        {{!-- "flex-group-center" is also defined in the _grid.scss file
        and it will add a small amount of padding, a border, and will
        center all of its child elements content and text. --}}
        <div class="resource flex-group-center">
          <label for="system.health.value" class="resource-label">Puntos de
            Vida</label>
          <div class="resource-content flexrow flex-center flex-between">
            <input type="number" name="system.health.value"
              value="{{system.health.value}}" data-dtype="Number" />
            <span> / </span>
            <input type="number" name="system.health.max"
              value="{{system.health.max}}" data-dtype="Number" />
          </div>
        </div>

        <div class="resource flex-group-center">
          <div class="ac-badge badge"
            aria-label="{{ localize 'system.attributes' }}">
            <div data-attribution="system.attributes.armorClass"
              data-attribution-caption="attributes.armorClass"
              data-tooltip-direction="DOWN">
              <label for="system.attributes.armorClass.value"
                class="resource-label">{{system.attributes.armorClass.label}}</label>
              <input type="number" name="system.attributes.armorClass.value"
                value="{{system.attributes.armorClass.value}}"
                data-dtype="Number" />
            </div>
          </div>
        </div>

        <div class="resource flex-group-center">
          <div class="ac-badge badge"
            aria-label="{{ localize 'system.attributes' }}">
            <div data-attribution="system.attributes.speed"
              data-attribution-caption="attributes.armorClass"
              data-tooltip-direction="DOWN">
              <label for="system.attributes.speed.value"
                class="resource-label">{{system.attributes.speed.label}}</label>
              <input type="number" name="system.attributes.speed.value"
                value="{{system.attributes.speed.value}}" data-dtype="Number"
                step="5" />
            </div>
          </div>
        </div>

      </div>
      <label class="resource-label">Atributos</label>
      <div class="grid-3col">
        <aside class="sidebar">
          {{!-- The grid classes are defined in scss/global/_grid.scss. To use,
          use both the "grid" and "grid-Ncol" class where "N" can be any number
          from 1 to 12 and will create that number of columns. --}}
          <div class="abilities grid grid-3col">
            {{#each system.abilities as |ability key|}}
            <div class="ability flexrow flex-group-center">
              <label for="system.abilities.{{key}}.value"
                class="resource-label rollable flexlarge align-left"
                data-roll="d20+@abilities.{{key}}.mod"
                data-label="{{localize (lookup @root.config.abilities key)}}">{{localize
                (lookup @root.config.abilities key)}}</label>
              <input type="number" name="system.abilities.{{key}}.value"
                value="{{ability.value}}" data-dtype="Number" />
              <span class="ability-mod rollable"
                data-roll="d20+@abilities.{{key}}.mod"
                data-label="{{localize (lookup @root.config.abilities key)}}">{{numberFormat
                ability.mod decimals=0 sign=true}}</span>
            </div>
            {{/each}}
          </div>
        </aside>
      </div>
    </div>
  </header>

  {{!-- Sheet Tab Navigation --}}
  <nav class="sheet-tabs tabs" data-group="primary">
    {{!-- Default tab is specified in actor-sheet.mjs --}}
    <a class="item" data-tab="description">Descripción</a>
    <a class="item" data-tab="items">Objetos</a>
    <a class="item" data-tab="effects">Efectos</a>
  </nav>

  {{!-- Sheet Body --}}
  <section class="sheet-body">

    {{!-- Biography Tab --}}
    <div class="tab biography" data-group="primary" data-tab="description">
      {{!-- Editors must receive enriched text data from getData to properly
      handle rolls --}}
      {{editor enrichedBiography target="system.biography" engine="prosemirror"
      button=true editable=editable}}
    </div>

    {{!-- Owned Items Tab --}}
    <div class="tab items" data-group="primary" data-tab="items">
      {{> "systems/tirduin/templates/actor/parts/actor-items.hbs"}}
    </div>

    {{!-- Active Effects Tab --}}
    <div class="tab effects flexcol" data-group="primary" data-tab="effects">
      {{> "systems/tirduin/templates/actor/parts/actor-effects.hbs"}}
    </div>

  </section>
</form>
