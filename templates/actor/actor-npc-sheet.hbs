<form class="{{cssClass}} {{actor.type}} flexcol" autocomplete="off">
  <section class="sheet-body npc-sheet">

    <header class="npc-header">

      <!-- IMAGEN -->
      <div class="npc-portrait">
        <img class="profile-img"
          src="{{actor.img}}"
          data-edit="img"
          title="{{actor.name}}" />
      </div>

      <!-- INFO PRINCIPAL -->
      <div class="npc-header-stats">

        <div class="npc-name">
          <input name="name" type="text" value="{{actor.name}}"
            placeholder="Nombre" />
        </div>

        <div class="npc-main">

          <div class="npc-stat">
            <label>PV</label>
            <div class="hp-row">
              <input type="number" name="system.health.value"
                value="{{system.health.value}}" min="0"
                onkeyup="if(value<0) value=0" />
              /
              <input type="number" name="system.health.max"
                value="{{system.health.max}}" min="0"
                onkeyup="if(value<0) value=0" />
            </div>
          </div>

          <div class="npc-stat">
            <label>CA</label>
            <input type="number" name="system.attributes.armorClass.value"
              value="{{system.attributes.armorClass.value}}" min="0"
              onkeyup="if(value<0) value=0" />
          </div>

          <div class="npc-stat">
            <label>Velocidad</label>
            <input type="number" name="system.attributes.speed.value"
              value="{{system.attributes.speed.value}}" min="0"
              onkeyup="if(value<0) value=0" />
          </div>

        </div>

      </div>

    </header>

    <!-- ATRIBUTOS -->
    <div class="npc-attributes">
      <h2>Atributos</h2>

      <div class="attr-row">

        {{#each system.abilities as |ability key|}}
        <div class="attr-box">
          <label for="system.abilities.{{key}}.value"
            class="resource-label rollable flexlarge align-left"
            data-roll="d20+{{numberFormat ability.value sign=true}}"
            data-label="{{localize (lookup @root.config.abilities key)}}">{{localize
            (lookup @root.config.abilities key)}}</label>

          <input type="number"
            name="system.abilities.{{key}}.value"
            value="{{ability.value}}"
            min="-5" max="5"
            onkeyup="if(value<-5) value=-5; if(value>5) value=5;" />

        </div>
        {{/each}}

      </div>
    </div>

    <!-- TABS NAVIGATION -->
    <nav class="sheet-tabs tabs" data-group="npc-sections">
      <a class="item active" data-tab="skills">Habilidades</a>
      <a class="item" data-tab="special">Especial</a>
      <a class="item" data-tab="abilities">Abilities</a>
      <a class="item" data-tab="fear">Fear</a>
    </nav>

    <!-- TABS CONTENT -->
    <div class="tabs-content">

      <!-- HABILIDADES TAB -->
      <div class="tab active" data-tab="skills">
        <div class="npc-skills">
          {{> "systems/tirduin/templates/actor/parts/actor-skills.hbs"}}
        </div>
      </div>

      <!-- ESPECIALES TAB -->
      <div class="tab" data-tab="special">
        <div class="npc-special">
          <label>Especial</label>
          <textarea name="system.special">{{system.special}}</textarea>
        </div>
      </div>

      <!-- ABILITIES TAB -->
      <div class="tab" data-tab="abilities">
        <div class="npc-abilities">
          <label>Abilities</label>
          <textarea name="system.abilities">{{system.abilities}}</textarea>
        </div>
      </div>

      <!-- FEAR TAB -->
      <div class="tab" data-tab="fear">
        <div class="npc-fear">
          <label>Fear</label>
          <textarea name="system.fear">{{system.fear}}</textarea>
        </div>
      </div>

    </div>

  </section>
</form>